APP_NAME=GraphRAGX
APP_ENV=dev
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/codegraphrag
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=code_chunks
QDRANT_TIMEOUT_SEC=10
QDRANT_UPSERT_BATCH_SIZE=256
QDRANT_UPSERT_MAX_RETRIES=2
ENABLE_EXTERNAL_STORES=true
REQUIRE_NEO4J=true
REQUIRE_QDRANT=true
DEFAULT_TOP_K=8
RETRIEVAL_CANDIDATE_MULTIPLIER=3
RETRIEVAL_GRAPH_HOPS=2
RETRIEVAL_GRAPH_LIMIT=80
RETRIEVAL_CONTEXT_LIMIT=8
RETRIEVAL_KEYWORD_LIMIT=80
RETRIEVAL_ENABLE_KEYWORD=true
EMBEDDING_PROVIDER=local_hash
EMBEDDING_MODEL=codegraphrag-local-v1
EMBEDDING_DIMENSIONS=384
EMBEDDING_API_BASE=
EMBEDDING_API_KEY=
EMBEDDING_TIMEOUT_SEC=30
EMBEDDING_BATCH_SIZE=32
CHUNK_MAX_LINES=120
CHUNK_MAX_CHARS=4000
WORKSPACE_REPOS_DIR=.workspace/repos
INDEX_MAX_FILES=20000
SYNC_MOCK_MODE=false
SYNC_STALE_MINUTES=120
SYNC_DIFF_RENAME_DETECTION=true
ENABLE_KNOWLEDGE_BASE=false
KNOWLEDGE_SUPPORTED_EXTS=md,txt,html,pdf,docx,json,jsonl
KNOWLEDGE_CHUNK_CHARS=1200
KNOWLEDGE_CHUNK_OVERLAP=120
CHAT_PROVIDER=none
CHAT_MODEL=gpt-4o-mini
CHAT_API_BASE=
CHAT_API_KEY=
CHAT_TEMPERATURE=0.2
CHAT_MAX_TOKENS=700
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=
OPENAI_WIRE_API=chat_completions
